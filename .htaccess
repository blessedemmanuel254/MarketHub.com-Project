# =========================================
# 🔒 SECURITY HEADERS (Like Amazon-level basics)
# =========================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# =========================================
# 🔐 FORCE HTTPS (VERY IMPORTANT FOR SEO)
# =========================================
RewriteEngine On

RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# =========================================
# 🌍 REMOVE WWW (or enforce it — choose one)
# =========================================
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# =========================================
# 🚫 BLOCK ACCESS TO SENSITIVE FILES
# =========================================
<FilesMatch "(connection\.php|\.env|composer\.json|composer\.lock|package\.json)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disable directory browsing
Options -Indexes

# =========================================
# 🧠 CLEAN URLS (SEO FRIENDLY)
# =========================================

# Property pages
RewriteRule ^property/([a-zA-Z0-9-]+)$ property.php?slug=$1 [L,QSA]

# Land pages
RewriteRule ^land/([a-zA-Z0-9-]+)$ land.php?slug=$1 [L,QSA]

# Category pages
RewriteRule ^category/([a-zA-Z0-9-]+)$ category.php?name=$1 [L,QSA]

# User profiles
RewriteRule ^user/([a-zA-Z0-9-]+)$ profile.php?username=$1 [L,QSA]

# Blog posts
RewriteRule ^blog/([a-zA-Z0-9-]+)$ blog.php?slug=$1 [L,QSA]

# =========================================
# 📄 REMOVE .php EXTENSION FROM URLS
# =========================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [L]

# Redirect .php to clean URL
RewriteCond %{THE_REQUEST} \s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# =========================================
# ⚡ CACHE CONTROL (BOOST SPEED)
# =========================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpg "access 1 year"
    ExpiresByType image/jpeg "access 1 year"
    ExpiresByType image/png "access 1 year"
    ExpiresByType image/webp "access 1 year"

    # CSS & JS
    ExpiresByType text/css "access 1 month"
    ExpiresByType application/javascript "access 1 month"

    # Fonts
    ExpiresByType font/woff2 "access 1 year"
</IfModule>

# =========================================
# 🗜️ ENABLE GZIP COMPRESSION
# =========================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript
</IfModule>

# =========================================
# 🚫 BLOCK BAD BOTS (Basic Protection)
# =========================================
RewriteCond %{HTTP_USER_AGENT} (curl|wget|python|scrapy|bot) [NC]
RewriteRule .* - [F,L]

# =========================================
# 🧭 CUSTOM ERROR PAGES (SEO FRIENDLY)
# =========================================
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php